{% extends 'base.html.twig' %}

{% block title %}Přihlášení!{% endblock %}

{% block body %}
    <form method="post">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                Přihlášen: {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Odhlásit</a>
            </div>
        {% endif %}
        <div class="row">
            <div class="col-lg-4 col-md-6 col-8">
                <h1 class="h3 mb-3 font-weight-normal">Přihlášení</h1>
                <label for="username">Uživatelské jméno</label>
                <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="username" required autofocus>
                <label for="password">Heslo</label>
                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">



                    <div class="checkbox mb-3">
                        <input type="checkbox" name="_remember_me" id="_remember_me">
                        <label for="_remember_me">Pamatovat si přihlášení</label>
                    </div>


                <button class="btn btn-lg btn-primary rounded-decently" type="submit">
                    Přihlásit
                </button>
            </div>
        </div>
    </form>
{% endblock %}
