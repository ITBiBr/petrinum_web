<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}Petrinum{% endblock %}</title>

    {# Webpack Encore CSS #}
    {{ encore_entry_link_tags('app') }}
</head>

<body class="d-flex flex-column min-vh-100">

<div class="hero-image">
    <img src="{{ asset('images/budova.jpg') }}" class="budova">
</div>
{# ====================== HLAVIČKA ====================== #}
<header class="sticky-top custom-navbar">
    <div class="navbar-wrapper">
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container align-items-end">

            <a class="navbar-brand fw-bold d-flex align-items-center" href="#">

                <img src="{{ asset('images/logo.svg') }}" alt="Logo" class="navbar-logo me-2 mb-3 mt-3">

                <div class="d-flex flex-column lh-sm ms-3 mb-3">
                    <span class="text-lowercase fs-5">Církevní domov mládeže</span>
                    <span class="text-lowercase fw-bold fs-1">Petrinum</span>
                </div>

            </a>

            <button class="navbar-toggler custom-toggler collapsed ms-auto mb-lg-0 mb-3" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse align-items-end" id="mainNavbar">
                <ul class="navbar-nav ms-auto align-items-end">

                    <li class="nav-item">
                        <a class="nav-link nav-link-fancy fs-5 fw-bold text-white" href="#">Domů</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-fancy fs-5 fw-bold text-white" href="#">O koleji</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-fancy fs-5 fw-bold text-white " href="#">Ubytování</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-fancy fs-5 fw-bold text-white" href="#">Kontakty</a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>
    </div>
</header>

{# ====================== OBSAH ====================== #}
<main class="flex-grow-1 py-4">
    <div class="container">
        {% block body %}{% endblock %}
    </div>
</main>

{# ====================== PATIČKA ====================== #}
<div class="footer-wrapper">
    <footer class="py-3 mt-auto">
        <div class="container text-center text-white small pt-5">
            © {{ "now"|date("Y") }} Petrinum
        </div>
        <div class="container text-center text-white small mb-5">
            Další text patičky
        </div>
    </footer>
</div>

{# Webpack Encore JS #}
{{ encore_entry_script_tags('app') }}
</body>
</html>
