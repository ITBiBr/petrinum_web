{% extends 'base.html.twig' %}

{% block title %}Zaměstnanci{% endblock %}

{% block body %}
    <div class="row justify-content-center text-center">
        <div class="col-12">
            <h2 class="text-primary fw-bolder text-uppercase">Zaměstnanci</h2>
        </div>
    </div>
    {% for kategorie in kategorieZamestnanci %}
        {% if kategorie.zamestnancis|length > 0 %}
        <div class="row justify-content-center mt-5">
            <div class="col-lg-8 col-12">
                <h3 class="text-primary border-bottom pb-2 mb-4">
                    {{ kategorie.nazev }}
                </h3>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8 col-12">
                <div class="row">
                {% for zamestnanec in kategorie.zamestnancis %}
                    <div class="col-6 col-md-4 col-lg-3 mb-4">
                        <div class="card h-100 shadow-sm border-0">


                                <img
                                    src="{% if zamestnanec.foto %}{{ asset('images/zamestnanci/' ~ zamestnanec.foto)| imagine_filter('zamestnanec_thumb') }}{% else %}{{ asset('images/kvetina.jpg')| imagine_filter('zamestnanec_thumb')}}{% endif %}"
                                    class="card-img-top"
                                    alt="{{ zamestnanec.jmeno }}"
                                >


                            <div class="card-body text-center">
                                <h5 class="card-title mb-1">
                                    {{ zamestnanec.jmeno }}
                                </h5>

                                {% if zamestnanec.role %}
                                    <p class="text-muted mb-3">
                                        {{ zamestnanec.role }}
                                    </p>
                                {% endif %}

                            </div>

                        </div>
                    </div>
                {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}
    {% endfor %}
{% endblock %}
